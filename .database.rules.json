{
  "rules": {
    ".read": "auth != null",
    ".write": false,
    "race": {
      ".write": "auth != null && (auth.token.email == 'joshelifaz@gmail.com' || root.child('settings/admins').child(auth.token.email.replace('.', ',')).val() == true)"
    },
    "races": {
      ".write": "auth != null && (auth.token.email == 'joshelifaz@gmail.com' || root.child('settings/admins').child(auth.token.email.replace('.', ',')).val() == true)"
    },
    "settings": {
      "admins": {
        ".write": "auth != null && auth.token.email == 'joshelifaz@gmail.com'"
      }
    }
  }
}
